{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "reference",
    "public/sw.js",
    "playwright-report",
    "test-results",
    "coverage"
  ]
}
