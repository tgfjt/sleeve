{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": true,
  "trailingComma": "none",
  "printWidth": 100,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "reference",
    "playwright-report",
    "test-results",
    "coverage",
    "public/sw.js"
  ]
}
